<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <!-- SIGNUP -->
    <servlet>
        <servlet-name>SignupServlet</servlet-name>
        <servlet-class>com.agrolink.servlets.SignupServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SignupServlet</servlet-name>
        <url-pattern>/api/auth/signup</url-pattern>
    </servlet-mapping>

    <!-- LOGIN -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.agrolink.servlets.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/api/auth/login</url-pattern>
    </servlet-mapping>

    <!-- GET PROFILE -->
    <servlet>
        <servlet-name>GetProfileServlet</servlet-name>
        <servlet-class>com.agrolink.servlets.GetProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GetProfileServlet</servlet-name>
        <url-pattern>/api/user/get-profile</url-pattern>
    </servlet-mapping>

    <!-- UPDATE PROFILE -->
    <servlet>
        <servlet-name>UpdateProfileServlet</servlet-name>
        <servlet-class>com.agrolink.servlets.UpdateProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateProfileServlet</servlet-name>
        <url-pattern>/api/user/update-profile</url-pattern>
    </servlet-mapping>

</web-app>
